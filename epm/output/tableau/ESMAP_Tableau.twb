      <column caption='Reserve over Energy' datatype='real' name='[Calculation_1997065025145597964]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([value (Union1)])/SUM([value (Union2)])' />
      </column>
      <column caption='Value Plant' datatype='real' name='[Calculation_214765471562522629]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Paramètre 4]&#13;&#10;WHEN &apos;Energy&apos; THEN SUM([value (Union2)])&#13;&#10;WHEN &apos;Capacity&apos; THEN SUM([value])&#13;&#10;WHEN &apos;Spinning reserves&apos; THEN SUM([value (Union1)])&#13;&#10;WHEN &apos;Utilization Rate&apos; then SUM([value (Union5)])&#13;&#10;WHEN &apos;Reserve to Energy Ratio&apos; then [Calculation_1997065025145597964]&#13;&#10;END' />

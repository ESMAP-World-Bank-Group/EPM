            </column>
            <column caption='Legend' datatype='string' name='[Calculation_804455501749575680]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Path - Split 2]&#13;&#10;WHEN &quot;pTechFuelMerged.csv&quot; THEN [techfuel]&#13;&#10;WHEN &quot;pYearlyCostsMerged.csv&quot; THEN [uni]&#13;&#10;WHEN &apos;pCapexInvestmentMerged.csv&apos; THEN [uni]&#13;&#10;END' />

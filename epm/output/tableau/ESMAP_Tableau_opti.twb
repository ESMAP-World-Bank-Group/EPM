      <column caption='Value Capacity String' datatype='string' name='[Calculation_1954562265125154818]' role='measure' type='nominal'>
        <calculation class='tableau' formula='if SUM([Calculation_367887813097623553])&gt;0 THEN &#13;&#10;STR(sum([Calculation_367887813097623553]))+&apos; MW&apos;&#13;&#10;END' />
      </column>
      <column caption='Sum Interchange' datatype='real' name='[Calculation_2388878146986115073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Value Utilization 1 (copy)_367887813111578639]+[Value Utilization 2 (copy)_367887813111922704]' />

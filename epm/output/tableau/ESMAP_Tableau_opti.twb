      <column caption='Sum Utilization' datatype='real' name='[Calculation_367887813099245573]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Value Capacity (copy)_367887813098795011]+[Calculation_367887813099110404]' />

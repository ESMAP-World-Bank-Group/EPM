        <column caption='Aggregation level' datatype='string' name='[Parameter 4]' param-domain-type='list' role='measure' type='nominal' value='&quot;Country&quot;'>
          <calculation class='tableau' formula='&quot;Country&quot;' />
          <members>
            <member value='&quot;Country&quot;' />
            <member value='&quot;Zone&quot;' />
          </members>
        </column>
        <column alias='Energy (GWh)' caption='Indicator Plant' datatype='string' name='[Parameter 6]' param-domain-type='list' role='measure' type='nominal' value='&quot;EnergyPlant&quot;'>
          <calculation class='tableau' formula='&quot;EnergyPlant&quot;' />
          <aliases>
            <alias key='&quot;CapacityPlant&quot;' value='Capacity (MW)' />
            <alias key='&quot;CostsPlant&quot;' value='Costs (m USD)' />
            <alias key='&quot;EnergyPlant&quot;' value='Energy (GWh)' />

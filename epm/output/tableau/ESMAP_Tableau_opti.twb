      <column caption='Pos Interchange' datatype='boolean' name='[Calculation_2388878146986237954]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_2388878146986115073]&gt;0' />
      </column>
      <column caption='Value Congestion 1' datatype='real' name='[Calculation_2388878146989457411]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='zn(CASE [attribute]&#13;&#10;WHEN &apos;CongestionShare&apos; THEN [value]&#13;&#10;END)' />
      </column>
      <column caption='Main Axis' datatype='string' name='[Calculation_367887813096222720]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Path - Split 2]&#13;&#10;WHEN &apos;pInterchange.csv&apos; THEN [z2]+&apos;&lt;==&gt;&apos;+[z]&#13;&#10;WHEN &apos;pInterconUtilization.csv&apos; THEN [z2]+&apos;&lt;==&gt;&apos;+[z]&#13;&#10;WHEN &apos;pCongestionShare.csv&apos; THEN [z2]+&apos;&lt;==&gt;&apos;+[z]&#13;&#10;ELSE [z]+&apos;&lt;==&gt;&apos;+[z2]&#13;&#10;END' />
      </column>
      <column caption='Value Capacity' datatype='real' name='[Calculation_367887813097623553]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='zn(CASE [attribute]&#13;&#10;WHEN &apos;AnnualTransmissionCapacity&apos; THEN [value]&#13;&#10;END)' />
      </column>
      <column caption='Value Utilization 2' datatype='real' name='[Calculation_367887813099110404]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='zn(CASE [Path - Split 2]&#13;&#10;WHEN &apos;pInterconUtilization.csv&apos; THEN [value]&#13;&#10;END)' />
